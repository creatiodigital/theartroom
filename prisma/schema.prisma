// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserType {
  artist
  admin
  curator
  general
}

model User {
  id          String       @id @default(uuid())
  name        String
  lastName    String
  userType    UserType     @default(general)
  handler     String       @unique
  biography   String
  email       String?      @unique
  password    String?
  exhibitions Exhibition[]
  artworks    Artwork[]
  accounts    Account[]
  sessions    Session[]
}

model Artwork {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  name        String
  artworkType String  @default("image")
  title       String?
  author      String?
  year        String?
  technique   String?
  dimensions  String?
  description String?
  imageUrl    String?

  exhibitionArtworks ExhibitionArtwork[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Exhibition {
  id           String    @id @default(uuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  handler      String
  mainTitle    String
  url          String    @unique
  thumbnailUrl String?
  bannerUrl    String?
  spaceId      String
  startDate    DateTime?
  endDate      DateTime?
  status       String
  visibility   String

  exhibitionArtworks ExhibitionArtwork[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ExhibitionArtwork {
  id           String     @id @default(uuid())
  exhibitionId String
  exhibition   Exhibition @relation(fields: [exhibitionId], references: [id], onDelete: Cascade)
  artworkId    String
  artwork      Artwork    @relation(fields: [artworkId], references: [id], onDelete: Cascade)

  wallId      String
  posX2d      Float
  posY2d      Float
  width2d     Float
  height2d    Float
  posX3d      Float
  posY3d      Float
  posZ3d      Float
  quaternionX Float
  quaternionY Float
  quaternionZ Float
  quaternionW Float

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([exhibitionId, artworkId])
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
