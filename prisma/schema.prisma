// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserType {
  artist
  admin
  superAdmin
  curator
  general
}

model User {
  id                 String   @id @default(uuid())
  name               String
  lastName           String
  userType           UserType @default(general)
  handler            String   @unique
  biography          String
  email              String?  @unique
  password           String?
  mustChangePassword Boolean  @default(false)
  profileImageUrl    String?
  // Transparent-PNG signature used on certificates of authenticity for
  // printed works by this artist. Nullable — certificates fall back to
  // the printed artist name when this is not yet set.
  signatureUrl       String?
  isFeatured         Boolean  @default(false)
  published          Boolean  @default(false)

  // Two-Factor Authentication
  totpSecret       String?
  twoFactorEnabled Boolean @default(false)

  // Magic Link Authentication
  magicLinkToken  String?
  magicLinkExpiry DateTime?

  // Email 2FA Login Code
  loginCode       String?
  loginCodeExpiry DateTime?

  // Stripe Connect (Express) — the artist's connected Stripe account.
  // `onboardingComplete` flips true once `account.updated` arrives with
  // charges_enabled + payouts_enabled. We never trust the client-side
  // return from the onboarding redirect on its own.
  stripeAccountId          String?
  stripeOnboardingComplete Boolean @default(false)

  exhibitions Exhibition[]
  artworks    Artwork[]
  presets     ArtworkPreset[]
  accounts    Account[]
  sessions    Session[]
  printOrders PrintOrder[]
}

model ArtworkPreset {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  name       String
  presetType String @default("image") // "image" or "text"

  // Dimensions
  width2d  Float @default(100)
  height2d Float @default(100)

  // Frame
  showFrame               Boolean @default(false)
  frameColor              String  @default("#000000")
  frameSize               Float   @default(5)
  frameThickness          Float   @default(0.5)
  frameMaterial           String  @default("plastic")
  frameCornerStyle        String  @default("mitered")
  frameTextureScale       Float   @default(2.0)
  frameTextureRotation    Float   @default(0)
  frameTextureRoughness   Float   @default(0.6)
  frameTextureNormalScale Float   @default(0.5)

  // Passepartout
  showPassepartout      Boolean @default(false)
  passepartoutColor     String  @default("#ffffff")
  passepartoutSize      Float   @default(10)
  passepartoutThickness Float   @default(0.3)

  // Support
  showSupport      Boolean @default(false)
  supportThickness Float   @default(2.0)
  supportColor     String  @default("#ffffff")

  // Shadow
  hideShadow Boolean @default(false)

  // Text styling (used when presetType = "text")
  fontFamily            String  @default("Montserrat")
  fontSize              Float   @default(16)
  fontWeight            String  @default("400")
  letterSpacing         Float   @default(0)
  lineHeight            Float   @default(1.4)
  textColor             String  @default("#000000")
  textBackgroundColor   String?
  textAlign             String  @default("left")
  textVerticalAlign     String  @default("top")
  textPadding           Float   @default(0)
  textPaddingTop        Float   @default(0)
  textPaddingBottom     Float   @default(0)
  textPaddingLeft       Float   @default(0)
  textPaddingRight      Float   @default(0)
  textThickness         Float   @default(0) // Card depth in cm (0-5), only when background color is set
  textBackgroundTexture String? // e.g. 'paper', 'cardboard'
  showTextBorder        Boolean @default(false)
  textBorderColor       String  @default("#c9a96e") // Decorative inset border color
  textBorderOffset      Float   @default(1.2) // Inset distance in cm
  showMonogram          Boolean @default(false)
  monogramColor         String  @default("#c0392b")
  monogramOpacity       Float   @default(1.0)
  monogramPosition      String  @default("bottom") // 'top' or 'bottom'
  monogramOffset        Float   @default(6)
  monogramSize          Float   @default(18) // Distance from edge as % of card height

  // Shape decoration properties
  shapeType    String @default("rectangle")
  shapeColor   String @default("#000000")
  shapeOpacity Float  @default(1.0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Artwork {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  name                 String
  slug                 String  @unique
  artworkType          String  @default("image")
  title                String  @default("Untitled")
  author               String?
  year                 String?
  technique            String?
  dimensions           String?
  description          String?
  imageUrl             String? // Web-optimized image (CDN)
  originalImageUrl     String? // High-res original for print fulfillment (no CDN)
  originalWidth        Int? // Original image width in pixels
  originalHeight       Int? // Original image height in pixels
  originalDpi          Int? // Image DPI from EXIF metadata
  originalFormat       String? // Original file format (JPEG, PNG, etc.)
  originalSizeBytes    Int? // Original file size in bytes
  textContent          String? // Fixed text content for stencil/text artworks
  soundUrl             String? // Audio file URL for sound artworks
  videoUrl             String? // Video file URL for video artworks
  featured             Boolean @default(false)
  hiddenFromExhibition Boolean @default(false)
  order                Int     @default(0)

  // Print sales (theprintspace fulfillment). `printEnabled` gates the
  // "Buy Printable" CTA + the /print wizard; when false the artwork page
  // shows "Inquire" instead. `printPriceCents` is the artist's cut
  // per print (the gallery markup + TPS cost stack on top at
  // checkout time). Nullable so we can distinguish "not set yet"
  // from a deliberate zero.
  printEnabled    Boolean @default(false)
  printPriceCents Int?

  // Per-artwork printing restrictions set by the artist. Canonical
  // PrintRestrictions shape: { allowed: { dimensionId: ids[] } }.
  // When null / missing / field missing, all options from the catalog
  // are offered. Each dimension is validated server-side at
  // PaymentIntent creation.
  printOptions    Json?

  exhibitionArtworks ExhibitionArtwork[]
  printOrders        PrintOrder[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PrintOrder {
  id              String @id @default(uuid())
  paymentIntentId String @unique

  artworkId    String
  artwork      Artwork @relation(fields: [artworkId], references: [id], onDelete: Restrict)
  artistUserId String
  artistUser   User    @relation(fields: [artistUserId], references: [id], onDelete: Restrict)

  buyerEmail      String
  buyerName       String
  shippingAddress Json // ShippingAddress snapshot at checkout time
  printConfig     Json // PrintConfig snapshot at checkout time
  country         String

  // All amounts in minor units (cents) for the given currency.
  totalCents              Int
  artistCents             Int
  galleryCents            Int
  // The two production-cost columns predate the TPS-only switch and
  // were originally named after the previous provider. Mapped to keep
  // their data in place; the Prisma field uses the neutral name.
  productionCents         Int    @map("prodigiItemCents")
  productionShippingCents Int    @map("prodigiShippingCents")
  customerVatCents        Int
  currency                String @default("eur")

  // 'processing' | 'succeeded' | 'failed' | 'refunded'
  paymentStatus String @default("processing")

  // Manual TPS fulfillment stage. Admin advances by hand from
  // /admin/orders after placing the order on theprintspace's portal.
  // Values: null (pending placement) | 'Placed' | 'Started' | 'Shipped'
  // | 'Complete' | 'Rejected'.
  fulfillmentStatus String?
  trackingUrl       String?
  shippedAt         DateTime?

  // Public R2 URL of the generated certificate of authenticity PDF that
  // ships with this order. Null until the cert has been rendered and
  // uploaded.
  certificateUrl String?

  // Stripe Connect transfer to the artist (null until admin releases payout).
  // 'pending' | 'paid' | 'reversed'
  transferId     String?
  transferStatus String?
  paidOutAt      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  events PrintOrderEvent[]

  @@index([artistUserId])
  @@index([paymentStatus, fulfillmentStatus, transferStatus])
}

// Append-only audit trail for everything that happens to a PrintOrder.
// Every webhook, every API call we make, every admin action emits a row.
// Used for debugging, incident review, and rendering the order timeline
// in the admin UI. Never update or delete rows in this table.
model PrintOrderEvent {
  id      String     @id @default(uuid())
  orderId String
  order   PrintOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  at      DateTime   @default(now())

  // e.g. 'auth_received', 'captured', 'capture_failed', 'shipped',
  // 'email_sent', 'admin_action'.
  kind String

  // 'stripe' | 'system' | 'admin:<userId>'
  actor String

  // Raw webhook/API payload. JSON so we can store whatever the source gave us.
  payload Json?

  // Short human-readable summary for the timeline view.
  message String?

  @@index([orderId, at])
  @@index([kind, at])
}

model Exhibition {
  id                String    @id @default(uuid())
  userId            String
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  handler           String
  mainTitle         String
  description       String?
  shortDescription  String?
  url               String    @unique
  thumbnailUrl      String?
  bannerUrl         String?
  featuredImageUrl  String?
  spaceId           String
  startDate         DateTime?
  endDate           DateTime?
  status            String
  published         Boolean   @default(false)
  publishedAt       DateTime? // When last published/updated
  publishedSnapshot Json? // Full snapshot at publish time
  hasPendingChanges Boolean   @default(false) // True when draft differs from published
  previewEnabled    Boolean   @default(false) // When true, visit route is accessible even if unpublished
  previewToken      String? // UUID token required in ?preview= param

  // Lighting customization (space-agnostic)
  ambientLightColor      String?  @default("#e4e8f2")
  ambientLightIntensity  Float?   @default(1.0)
  skylightColor          String?  @default("#ffffff")
  skylightIntensity      Float?   @default(4.0)
  ceilingLampColor       String?  @default("#ffffff")
  ceilingLampIntensity   Float?   @default(4.0)
  trackLampColor         String?  @default("#ffffff")
  trackLampIntensity     Float?   @default(4.0)
  trackLampsVisible      Boolean? @default(true)
  recessedLampColor      String?  @default("#ffffff")
  recessedLampIntensity  Float?   @default(4.0)
  recessedLampAngle      Float?   @default(0.45)
  recessedLampDistance   Float?   @default(15.0)
  trackLampMaterialColor String?  @default("#ffffff")
  trackLampAngle         Float?   @default(0.45)
  trackLampDistance      Float?   @default(5.0)
  trackLampSettings      Json?
  windowLightColor       String?  @default("#ffffff")
  windowLightIntensity   Float?   @default(4.0)
  windowTransparency     Boolean? @default(false)
  hdriRotation           Float?   @default(128)
  floorReflectiveness    Float?   @default(0.3)
  floorMaterial          String?  @default("concrete")
  floorTextureScale      Float?   @default(1.0)
  floorTextureOffsetX    Float?   @default(0)
  floorTextureOffsetY    Float?   @default(0)
  floorTemperature       Float?   @default(0)
  floorNormalScale       Float?   @default(1.0)
  floorRotation          Float?   @default(0)
  // HDRI environment
  hdriEnvironment        String?  @default("soil")
  ceilingLightMode       String?  @default("track-plafond")
  // Camera settings
  cameraFOV              Float?   @default(50)
  cameraElevation        Float?   @default(1.6)

  // Wall & Ceiling customization
  wallColor      String? @default("#ffffff")
  ceilingColor   String? @default("#ffffff")
  wallBrightness Float?  @default(1.8)

  // Shadow decal controls
  shadowBlur      Float? @default(0.025)
  shadowSpread    Float? @default(1.2)
  shadowOpacity   Float? @default(0.25)
  shadowDirection Float? @default(0.2)

  // Autofocus groups (JSON array of { id, name, artworkIds })
  autofocusGroups Json?

  exhibitionArtworks ExhibitionArtwork[]
  wallGuides         WallGuide[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ExhibitionArtwork {
  id           String     @id @default(uuid())
  exhibitionId String
  exhibition   Exhibition @relation(fields: [exhibitionId], references: [id], onDelete: Cascade)
  artworkId    String
  artwork      Artwork    @relation(fields: [artworkId], references: [id], onDelete: Cascade)

  wallId      String
  posX2d      Float
  posY2d      Float
  width2d     Float
  height2d    Float
  posX3d      Float
  posY3d      Float
  posZ3d      Float
  quaternionX Float
  quaternionY Float
  quaternionZ Float
  quaternionW Float

  // Display properties (per-exhibition customization)
  showFrame               Boolean @default(false)
  frameColor              String  @default("#000000")
  frameSize               Float   @default(5) // Border width (XY)
  frameThickness          Float   @default(0.5) // Z-depth
  frameMaterial           String  @default("plastic")
  frameCornerStyle        String  @default("mitered")
  frameTextureScale       Float   @default(2.0)
  frameTextureRotation    Float   @default(0)
  frameTextureRoughness   Float   @default(0.6)
  frameTextureNormalScale Float   @default(0.5)
  showPassepartout        Boolean @default(false)
  passepartoutColor       String  @default("#ffffff")
  passepartoutSize        Float   @default(10) // Border width around artwork (XY)
  passepartoutThickness   Float   @default(0.3) // Z-depth of passepartout in 3D
  showArtworkInformation  Boolean @default(false)

  // Support (canvas/panel depth) - rendering depth behind artwork
  showSupport      Boolean @default(false) // Whether support is visible
  supportThickness Float   @default(2.0) // Depth in cm (0-10)
  supportColor     String  @default("#ffffff") // Edge color

  // Shadow
  hideShadow Boolean @default(false) // Whether to hide artwork shadow

  // Text styling (per-exhibition customization)
  fontFamily            String  @default("Montserrat")
  fontSize              Float   @default(16)
  fontWeight            String  @default("400")
  letterSpacing         Float   @default(0)
  lineHeight            Float   @default(1.4)
  textColor             String  @default("#000000")
  textBackgroundColor   String?
  textAlign             String  @default("left")
  textVerticalAlign     String  @default("top")
  textPadding           Float   @default(0) // Padding in pixels
  textPaddingTop        Float   @default(0)
  textPaddingBottom     Float   @default(0)
  textPaddingLeft       Float   @default(0)
  textPaddingRight      Float   @default(0)
  textThickness         Float   @default(0) // Card depth in cm (0-5), only when background color is set
  textBackgroundTexture String? // e.g. 'paper', 'cardboard'
  showTextBorder        Boolean @default(false)
  textBorderColor       String  @default("#c9a96e")
  textBorderOffset      Float   @default(1.2)
  showMonogram          Boolean @default(false)
  monogramColor         String  @default("#c0392b")
  monogramOpacity       Float   @default(1.0)
  monogramPosition      String  @default("bottom")
  monogramOffset        Float   @default(6)
  monogramSize          Float   @default(18)

  // Sound styling (per-exhibition customization)
  soundIcon            String  @default("volume-2")
  soundBackgroundColor String?
  soundIconColor       String  @default("#000000")
  soundIconSize        Int     @default(24)
  soundPlayMode        String  @default("play-once")
  soundSpatial         Boolean @default(true)
  soundDistance        Float   @default(5)

  // Shape decoration properties (only used when artwork.artworkType = 'shape')
  shapeType    String @default("rectangle") // rectangle | circle
  shapeColor   String @default("#000000")
  shapeOpacity Float  @default(1.0)

  // Video playback (per-exhibition)
  videoPlayMode          String  @default("proximity") // 'proximity' | 'always' | 'click'
  videoLoop              Boolean @default(true) // Whether video loops
  videoVolume            Float   @default(1.0) // Volume level 0-1
  videoProximityDistance Float   @default(3) // Distance in meters to trigger play

  // Wall-normal rotation (degrees, 0-360, only used for shapes)
  rotation Float @default(0)

  // Lock protection (prevents move, resize, delete, preset, and grouping in wall view)
  locked Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([exhibitionId, artworkId])
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Slide {
  id            String   @id @default(uuid())
  order         Int      @default(0)
  imageUrl      String
  title         String
  subtitle      String
  meta          String // e.g. "7 NOV 2025 - 17 JAN 2026    NEW YORK"
  exhibitionUrl String
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model PageContent {
  id        String   @id @default(uuid())
  slug      String   @unique // "about", "terms", "privacy", "accessibility", "prints"
  title     String
  content   String // HTML from TipTap
  // Top banner image. Currently only used by the "prints" page; other
  // pages leave it null. Stored as an R2 public URL.
  bannerImageUrl String?
  updatedAt DateTime @updatedAt
}

model WallGuide {
  id           String     @id @default(uuid())
  exhibitionId String
  exhibition   Exhibition @relation(fields: [exhibitionId], references: [id], onDelete: Cascade)
  wallId       String
  orientation  String // "horizontal" | "vertical"
  position     Float // position in metres from wall origin

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([exhibitionId, wallId])
}
