// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserType {
  artist
  admin
  superAdmin
  curator
  general
}

model User {
  id                 String   @id @default(uuid())
  name               String
  lastName           String
  userType           UserType @default(general)
  handler            String   @unique
  biography          String
  email              String?  @unique
  password           String?
  mustChangePassword Boolean  @default(false)
  profileImageUrl    String?
  isFeatured         Boolean  @default(false)
  published          Boolean  @default(false)

  // Two-Factor Authentication
  totpSecret       String?
  twoFactorEnabled Boolean @default(false)

  // Magic Link Authentication
  magicLinkToken  String?
  magicLinkExpiry DateTime?

  // Email 2FA Login Code
  loginCode       String?
  loginCodeExpiry DateTime?

  exhibitions Exhibition[]
  artworks    Artwork[]
  presets     ArtworkPreset[]
  accounts    Account[]
  sessions    Session[]
}

model ArtworkPreset {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  name       String
  presetType String @default("image") // "image" or "text"

  // Dimensions
  width2d  Float @default(100)
  height2d Float @default(100)

  // Frame
  showFrame      Boolean @default(false)
  frameColor     String  @default("#000000")
  frameSize      Float   @default(5)
  frameThickness Float   @default(0.5)

  // Passepartout
  showPassepartout      Boolean @default(false)
  passepartoutColor     String  @default("#ffffff")
  passepartoutSize      Float   @default(10)
  passepartoutThickness Float   @default(0.3)

  // Support
  showSupport      Boolean @default(false)
  supportThickness Float   @default(2.0)
  supportColor     String  @default("#ffffff")

  // Shadow
  hideShadow Boolean @default(false)

  // Text styling (used when presetType = "text")
  fontFamily          String  @default("Montserrat")
  fontSize            Float   @default(16)
  fontWeight          String  @default("400")
  letterSpacing       Float   @default(0)
  lineHeight          Float   @default(1.4)
  textColor           String  @default("#000000")
  textBackgroundColor String?
  textAlign           String  @default("left")
  textVerticalAlign   String  @default("top")
  textPadding         Float   @default(12)
  textThickness       Float   @default(0) // Card depth in cm (0-5), only when background color is set

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Artwork {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  name                 String
  artworkType          String  @default("image")
  title                String  @default("Untitled")
  author               String?
  year                 String?
  technique            String?
  dimensions           String?
  description          String?
  imageUrl             String?
  originalWidth        Int? // Original image width in pixels
  originalHeight       Int? // Original image height in pixels
  textContent          String? // Fixed text content for stencil/text artworks
  soundUrl             String? // Audio file URL for sound artworks
  featured             Boolean @default(false)
  hiddenFromExhibition Boolean @default(false)
  order                Int     @default(0)

  exhibitionArtworks ExhibitionArtwork[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Exhibition {
  id                String    @id @default(uuid())
  userId            String
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  handler           String
  mainTitle         String
  description       String?
  shortDescription  String?
  url               String    @unique
  thumbnailUrl      String?
  bannerUrl         String?
  featuredImageUrl  String?
  spaceId           String
  startDate         DateTime?
  endDate           DateTime?
  status            String
  published         Boolean   @default(false)
  publishedAt       DateTime? // When last published/updated
  publishedSnapshot Json? // Full snapshot at publish time
  hasPendingChanges Boolean   @default(false) // True when draft differs from published

  // Lighting customization (space-agnostic)
  ambientLightColor      String?  @default("#e4e8f2")
  ambientLightIntensity  Float?   @default(1.0)
  skylightColor          String?  @default("#ffffff")
  skylightIntensity      Float?   @default(4.0)
  ceilingLampColor       String?  @default("#ffffff")
  ceilingLampIntensity   Float?   @default(4.0)
  trackLampColor         String?  @default("#ffffff")
  trackLampIntensity     Float?   @default(4.0)
  trackLampsVisible      Boolean? @default(true)
  recessedLampColor      String?  @default("#ffffff")
  recessedLampIntensity  Float?   @default(4.0)
  trackLampMaterialColor String?  @default("#ffffff")
  trackLampAngle         Float?   @default(0.45)
  trackLampDistance      Float?   @default(5.0)
  windowLightColor       String?  @default("#ffffff")
  windowLightIntensity   Float?   @default(4.0)
  windowTransparency     Boolean? @default(false)
  hdriRotation           Float?   @default(128)
  floorReflectiveness    Float?   @default(0.3)
  floorMaterial          String?  @default("concrete")
  floorTextureScale      Float?   @default(1.0)
  floorTextureOffsetX    Float?   @default(0)
  floorTextureOffsetY    Float?   @default(0)
  floorTemperature       Float?   @default(0)
  floorNormalScale       Float?   @default(1.0)
  floorRotation          Float?   @default(0)
  // HDRI environment
  hdriEnvironment        String?  @default("soil")
  ceilingLightMode       String?  @default("track-plafond")
  // Camera settings
  cameraFOV              Float?   @default(50)
  cameraElevation        Float?   @default(1.6)
  // Furniture
  benchVisible           Boolean? @default(false)
  benchPositionX         Float?   @default(0)
  benchPositionZ         Float?   @default(0)
  benchRotationY         Float?   @default(0)
  // Wall & Ceiling customization
  wallColor              String?  @default("#ffffff")
  ceilingColor           String?  @default("#ffffff")

  exhibitionArtworks ExhibitionArtwork[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ExhibitionArtwork {
  id           String     @id @default(uuid())
  exhibitionId String
  exhibition   Exhibition @relation(fields: [exhibitionId], references: [id], onDelete: Cascade)
  artworkId    String
  artwork      Artwork    @relation(fields: [artworkId], references: [id], onDelete: Cascade)

  wallId      String
  posX2d      Float
  posY2d      Float
  width2d     Float
  height2d    Float
  posX3d      Float
  posY3d      Float
  posZ3d      Float
  quaternionX Float
  quaternionY Float
  quaternionZ Float
  quaternionW Float

  // Display properties (per-exhibition customization)
  showFrame              Boolean @default(false)
  frameColor             String  @default("#000000")
  frameSize              Float   @default(5) // Border width (XY)
  frameThickness         Float   @default(0.5) // Z-depth
  showPassepartout       Boolean @default(false)
  passepartoutColor      String  @default("#ffffff")
  passepartoutSize       Float   @default(10) // Border width around artwork (XY)
  passepartoutThickness  Float   @default(0.3) // Z-depth of passepartout in 3D
  showArtworkInformation Boolean @default(false)

  // Support (canvas/panel depth) - rendering depth behind artwork
  showSupport      Boolean @default(false) // Whether support is visible
  supportThickness Float   @default(2.0) // Depth in cm (0-10)
  supportColor     String  @default("#ffffff") // Edge color

  // Shadow
  hideShadow Boolean @default(false) // Whether to hide artwork shadow

  // Text styling (per-exhibition customization)
  fontFamily          String  @default("Montserrat")
  fontSize            Float   @default(16)
  fontWeight          String  @default("400")
  letterSpacing       Float   @default(0)
  lineHeight          Float   @default(1.4)
  textColor           String  @default("#000000")
  textBackgroundColor String?
  textAlign           String  @default("left")
  textVerticalAlign   String  @default("top")
  textPadding         Float   @default(12) // Padding in pixels
  textThickness       Float   @default(0) // Card depth in cm (0-5), only when background color is set

  // Sound styling (per-exhibition customization)
  soundIcon            String  @default("volume-2")
  soundBackgroundColor String?
  soundIconColor       String  @default("#000000")
  soundIconSize        Int     @default(24)
  soundPlayMode        String  @default("play-once")
  soundSpatial         Boolean @default(true)
  soundDistance        Float   @default(5)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([exhibitionId, artworkId])
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Slide {
  id            String   @id @default(uuid())
  order         Int      @default(0)
  imageUrl      String
  title         String
  subtitle      String
  meta          String // e.g. "7 NOV 2025 - 17 JAN 2026    NEW YORK"
  exhibitionUrl String
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model PageContent {
  id        String   @id @default(uuid())
  slug      String   @unique // "about", "terms", "privacy", "accessibility"
  title     String
  content   String // HTML from TipTap
  updatedAt DateTime @updatedAt
}
