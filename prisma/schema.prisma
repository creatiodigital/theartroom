// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserType {
  artist
  admin
  curator
  general
}

model User {
  id              String       @id @default(uuid())
  name            String
  lastName        String
  userType        UserType     @default(general)
  handler         String       @unique
  biography       String
  email           String?      @unique
  password        String?
  profileImageUrl String?
  isFeatured      Boolean      @default(false)
  exhibitions     Exhibition[]
  artworks        Artwork[]
  accounts        Account[]
  sessions        Session[]
}

model Artwork {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  name                 String
  artworkType          String  @default("image")
  title                String  @default("Untitled")
  author               String?
  year                 String?
  technique            String?
  dimensions           String?
  description          String?
  imageUrl             String?
  textContent          String? // Fixed text content for stencil/text artworks
  featured             Boolean @default(false)
  hiddenFromExhibition Boolean @default(false)

  exhibitionArtworks ExhibitionArtwork[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Exhibition {
  id               String    @id @default(uuid())
  userId           String
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  handler          String
  mainTitle        String
  description      String?
  url              String    @unique
  thumbnailUrl     String?
  bannerUrl        String?
  featuredImageUrl String?
  spaceId          String
  startDate        DateTime?
  endDate          DateTime?
  status           String
  visibility       String

  // Lighting customization (space-agnostic)
  ambientLightColor     String? @default("#e4e8f2")
  ambientLightIntensity Float?  @default(1.0)

  exhibitionArtworks ExhibitionArtwork[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ExhibitionArtwork {
  id           String     @id @default(uuid())
  exhibitionId String
  exhibition   Exhibition @relation(fields: [exhibitionId], references: [id], onDelete: Cascade)
  artworkId    String
  artwork      Artwork    @relation(fields: [artworkId], references: [id], onDelete: Cascade)

  wallId      String
  posX2d      Float
  posY2d      Float
  width2d     Float
  height2d    Float
  posX3d      Float
  posY3d      Float
  posZ3d      Float
  quaternionX Float
  quaternionY Float
  quaternionZ Float
  quaternionW Float

  // Display properties (per-exhibition customization)
  showFrame              Boolean @default(false)
  frameColor             String  @default("#000000")
  frameThickness         Float   @default(5)
  showPassepartout       Boolean @default(false)
  passepartoutColor      String  @default("#ffffff")
  passepartoutThickness  Float   @default(10)
  showArtworkInformation Boolean @default(false)

  // Text styling (per-exhibition customization)
  fontFamily          String  @default("Montserrat")
  fontSize            Float   @default(16)
  fontWeight          String  @default("400")
  letterSpacing       Float   @default(0)
  lineHeight          Float   @default(1.4)
  textColor           String  @default("#000000")
  textBackgroundColor String?
  textAlign           String  @default("left")
  textVerticalAlign   String  @default("top")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([exhibitionId, artworkId])
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Slide {
  id            String   @id @default(uuid())
  order         Int      @default(0)
  imageUrl      String
  title         String
  subtitle      String
  meta          String // e.g. "7 NOV 2025 - 17 JAN 2026    NEW YORK"
  exhibitionUrl String
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model PageContent {
  id        String   @id @default(uuid())
  slug      String   @unique // "about", "terms", "privacy", "accessibility"
  title     String
  content   String // HTML from TipTap
  updatedAt DateTime @updatedAt
}
