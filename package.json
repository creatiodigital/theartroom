{
  "name": "the-art-room",
  "version": "3.7.8",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3001",
    "build": "pnpm prisma generate --config ./prisma/prisma.config.ts && next build",
    "start": "next start -p 3001",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "check-format": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "db:push": "npx prisma db push --config prisma/prisma.config.ts",
    "db:push:prod": "dotenv -e .env.db.prod -- npx prisma db push --config prisma/prisma.config.ts",
    "db:push:dev": "dotenv -e .env.db.dev -- npx prisma db push --config prisma/prisma.config.ts",
    "db:generate": "npx prisma generate --config prisma/prisma.config.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:send-emails": "E2E_SEND_EMAILS=true playwright test",
    "test:e2e:prod-build": "E2E_PROD_BUILD=true playwright test",
    "test:e2e:install": "playwright install chromium",
    "prepare": "husky"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "engines": {
    "pnpm": ">=8.0.0"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1013.0",
    "@aws-sdk/s3-request-presigner": "^3.1013.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@neondatabase/serverless": "^1.0.2",
    "@prisma/adapter-neon": "^7.5.0",
    "@prisma/client": "7.5.0",
    "@prisma/client-runtime-utils": "^7.5.0",
    "@react-pdf/renderer": "^4.5.1",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@react-three/postprocessing": "^3.0.4",
    "@reduxjs/toolkit": "^2.11.2",
    "@sentry/nextjs": "^10.43.0",
    "@stripe/react-stripe-js": "^6.2.0",
    "@stripe/stripe-js": "^9.2.0",
    "@tiptap/extension-link": "^3.23.1",
    "@tiptap/extension-placeholder": "^3.20.1",
    "@tiptap/pm": "^3.20.1",
    "@tiptap/react": "^3.20.1",
    "@tiptap/starter-kit": "^3.20.1",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "bcryptjs": "^3.0.3",
    "classnames": "^2.5.1",
    "dotenv": "^17.3.1",
    "isomorphic-dompurify": "^3.12.0",
    "lucide-react": "^0.562.0",
    "next": "^16.1.6",
    "next-auth": "5.0.0-beta.30",
    "postprocessing": "^6.38.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-error-boundary": "^6.1.1",
    "react-redux": "^9.1.2",
    "resend": "^6.9.3",
    "sharp": "^0.34.5",
    "stripe": "^22.0.1",
    "swiper": "^12.1.2",
    "three": "^0.175.0",
    "three-stdlib": "^2.36.1",
    "utif": "^3.1.0",
    "uuid": "^11.0.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@gltf-transform/core": "^4.3.0",
    "@gltf-transform/extensions": "^4.3.0",
    "@gltf-transform/functions": "^4.3.0",
    "@next/eslint-plugin-next": "^16.2.3",
    "@playwright/test": "^1.59.1",
    "@svgr/webpack": "^8.1.0",
    "@types/node": "^24.3.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.179.0",
    "@types/utif": "^3.0.6",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "autoprefixer": "^10.4.27",
    "dotenv-cli": "^11.0.0",
    "draco3dgltf": "^1.5.7",
    "eslint": "^9.39.1",
    "eslint-config-next": "16.2.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "husky": "^9.1.7",
    "pg": "^8.20.0",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "prisma": "^7.5.0",
    "sass": "^1.98.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.1"
  }
}
