{
  "name": "the-art-room",
  "version": "3.3.29",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "pnpm prisma generate --config ./prisma/prisma.config.ts && next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "format": "prettier --write .",
    "check-format": "prettier --check .",
    "compress-glb": "node scripts/compress-glb-ktx2.mjs",
    "db:push": "npx prisma db push --config prisma/prisma.config.ts",
    "db:push:prod": "dotenv -e .env.db.prod -- npx prisma db push --config prisma/prisma.config.ts",
    "db:push:dev": "dotenv -e .env.db.dev -- npx prisma db push --config prisma/prisma.config.ts",
    "db:generate": "npx prisma generate --config prisma/prisma.config.ts"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "engines": {
    "pnpm": ">=8.0.0"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@neondatabase/serverless": "^1.0.2",
    "@prisma/adapter-neon": "^7.3.0",
    "@prisma/client": "7.1.0",
    "@prisma/client-runtime-utils": "^7.1.0",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.4.0",
    "@react-three/postprocessing": "^3.0.4",
    "@reduxjs/toolkit": "^2.3.0",
    "@tiptap/extension-placeholder": "^3.14.0",
    "@tiptap/pm": "^3.14.0",
    "@tiptap/react": "^3.14.0",
    "@tiptap/starter-kit": "^3.14.0",
    "@vercel/blob": "^2.0.0",
    "bcryptjs": "^3.0.3",
    "classnames": "^2.5.1",
    "dompurify": "^3.3.1",
    "dotenv": "^17.2.3",
    "lucide-react": "^0.562.0",
    "next": "^16.0.7",
    "next-auth": "5.0.0-beta.30",
    "postprocessing": "^6.38.2",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-error-boundary": "^6.0.3",
    "react-redux": "^9.1.2",
    "resend": "^6.8.0",
    "sharp": "^0.34.5",
    "swiper": "^12.0.3",
    "three": "^0.175.0",
    "three-stdlib": "^2.36.0",
    "uuid": "^11.0.3"
  },
  "devDependencies": {
    "@gltf-transform/core": "^4.1.1",
    "@gltf-transform/extensions": "^4.1.1",
    "@gltf-transform/functions": "^4.1.1",
    "@svgr/webpack": "^8.1.0",
    "@types/bcryptjs": "^3.0.0",
    "@types/classnames": "^2.3.4",
    "@types/dompurify": "^3.2.0",
    "@types/node": "^24.3.0",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@types/three": "^0.179.0",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.40.0",
    "@typescript-eslint/parser": "^8.40.0",
    "autoprefixer": "^10.0.1",
    "dotenv-cli": "^11.0.0",
    "draco3dgltf": "^1.5.7",
    "eslint": "^9.39.1",
    "eslint-config-next": "16.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.1.3",
    "pg": "^8.16.3",
    "postcss": "^8",
    "prettier": "^3.6.2",
    "prisma": "^7.1.0",
    "sass": "^1.77.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.2"
  }
}
